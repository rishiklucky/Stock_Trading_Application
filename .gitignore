# Root .gitignore for Stock Trading Application

# Build artifacts and generated files
/stock-app-backend/target/
/stock-app-frontend/build/

# Node dependencies
/stock-app-frontend/node_modules/

# IDE and editor settings
/.idea/
/.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db

# Logs and runtime files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.*

# Maven wrapper jars
/stock-app-backend/.mvn/wrapper/maven-wrapper.jar
